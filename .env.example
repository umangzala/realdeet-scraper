# .env.example — Copy to .env and fill in your values

# ── Twitter Account (used for session auth — use a dedicated research account) ──
TWITTER_HANDLE=your_twitter_handle
TWITTER_EMAIL=your_twitter_email@example.com
TWITTER_PASSWORD=your_twitter_password

# ── OpenAI (for GPT-4o-mini classification) ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Optional: Slack webhook for high-urgency alerts ──────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Optional: Proxy (use residential proxies for Twitter) ────────────────────
# Single proxy: set PROXY_URL (supports http, https, socks5)
PROXY_URL=http://user:pass@proxy-host:port
#
# Proxy pool: create a proxies.txt file with one proxy URL per line
# (PROXY_URL takes precedence if both are set)
